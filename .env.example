# Copiá este archivo a .env.local y completá con tus credenciales de Supabase.
#
# URL: Settings → Data API (o Connect). Solo la base del proyecto, SIN /rest/v1/
# Key: Settings → API Keys → Publishable key (sb_publishable_...)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key

# Animaciones de motion (false para deshabilitar)
VITE_ANIMATIONS_ENABLED=true
